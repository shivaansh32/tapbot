# ==============================
# TAPBOT - Environment Variables
# ==============================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:your_bot_token_here
# Get this from @BotFather on Telegram

# --- MongoDB ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tapbot
# For MongoDB Atlas (cloud): mongodb+srv://user:pass@cluster.mongodb.net/tapbot

# --- Server ---
PORT=3000
NODE_ENV=production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_now
ADMIN_SECRET=replace_with_a_long_random_secret

# --- Game Config ---
COINS_PER_TAP=1
MAX_TAPS_PER_DAY=3000
MAX_TAPS_PER_SECOND=5
# Minimum coins required before withdrawal request
MIN_WITHDRAWAL_COINS=10000
